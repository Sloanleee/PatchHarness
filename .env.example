# PatchHarness runtime flags
# Default is mock so local demos, Docker, and CI do not require real LLM keys.
# Options: mock, deepseek, ark, volcengine, volcengine_ark
PATCHHARNESS_LLM_PROVIDER=mock

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Volcengine Ark
ARK_API_KEY=
ARK_MODEL=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_TIMEOUT_SECONDS=300
